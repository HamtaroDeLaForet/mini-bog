{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container mt-5" style="max-width: 700px;">

    <h1>Mon Profil</h1>

    <div class="card mb-4">
        <div class="card-body text-center py-4">
            {% if user.profilePicture %}
            <img src="{{ '/uploads/profiles/' ~ user.profilePicture }}" class="rounded-circle mb-3"
                style="width: 120px; height: 120px; object-fit: cover; border: 4px solid var(--primary);"
                alt="Photo de profil">
            {% else %}
            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center mx-auto mb-3"
                style="width: 120px; height: 120px;">
                <span style="font-size: 3rem; color: white;">
                    {{ user.firstName|first|upper }}
                </span>
            </div>
            {% endif %}
            <h4 class="mb-0">{{ user.firstName }} {{ user.lastName }}</h4>
            <p class="text-muted">@{{ user.username }}</p>
            <small class="text-muted">Membre depuis le {{ user.createdAt|date('d/m/Y') }}</small>
        </div>
    </div>

    {# ... ton code existant ... #}

    <div class="card mt-4">
        <div class="card-body p-4">
            <h5 class="mb-4" style="font-weight: 700;">
                Mes commentaires
                <span class="badge bg-primary ms-2" style="font-size: 0.8rem;">{{ comments|length }}</span>
            </h5>

            {% if comments is empty %}
            <p class="text-muted text-center py-3">Tu n'as pas encore posté de commentaire.</p>
            {% else %}
            <div class="d-flex flex-column gap-3">
                {% for comment in comments %}
                <div class="border rounded p-3" style="background: var(--bs-light, #f8f9fa);">

                    {# Lien vers le post associé #}
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <a href="{{ path('app_post_show', { id: comment.post.id }) }}"
                            class="fw-semibold text-decoration-none text-primary">
                            {{ comment.post.title }}
                        </a>
                        <small class="text-muted ms-3 text-nowrap">
                            {{ comment.createdAt|date('d/m/Y à H:i') }}
                        </small>
                    </div>

                    <p class="mb-0 text-muted" style="font-size: 0.95rem;">
                        {{ comment.content }}
                    </p>

                </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>

    <div class="card">
        <div class="card-body p-4">
            <h5 class="mb-4" style="font-weight: 700;">Modifier mes informations</h5>

            {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.firstName) }}
                    {{ form_widget(form.firstName, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_label(form.lastName) }}
                    {{ form_widget(form.lastName, {'attr': {'class': 'form-control'}}) }}
                </div>
            </div>

            <div class="mb-3">
                {{ form_label(form.username) }}
                {{ form_widget(form.username, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="mb-4">
                {{ form_label(form.profilePictureFile) }}
                {{ form_widget(form.profilePictureFile, {'attr': {'class': 'form-control'}}) }}
                <small class="text-muted">Format JPG, PNG — max 2Mo</small>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Sauvegarder les modifications
            </button>

            {{ form_end(form) }}
        </div>
    </div>

</div>
{% endblock %}