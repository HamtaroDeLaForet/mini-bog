{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="mb-4">
        {% if post.picture %}
        {% if 'http' in post.picture %}
        <img src="{{ post.picture }}" class="img-fluid rounded mb-3"
            style="max-height: 400px; width: 100%; object-fit: cover;">
        {% else %}
        <img src="{{ '/uploads/posts/' ~ post.picture }}" class="img-fluid rounded mb-3"
            style="max-height: 400px; width: 100%; object-fit: cover;">
        {% endif %}
        {% endif %}
        <h1>{{ post.title }}</h1>
        <p class="text-muted">
            <small>
                {{ post.createdAt|date('d/m/Y') }}
                {% if post.user %} — {{ post.user }}{% endif %}
                {% if post.category %} — {{ post.category }}{% endif %}
            </small>
        </p>
        <div class="post-content">
            {{ post.content|nl2br }}
        </div>
        <a href="{{ path(backRoute) }}" class="btn btn-secondary mt-3">← Retour</a>
    </div>

    <hr>

    <h3>Commentaires ({{ comments|length }})</h3>

    {% for comment in comments %}
    <div class="card mb-3">
        <div class="card-body">
            <p class="mb-1">{{ comment.content }}</p>
            <small class="text-muted">
                {{ comment.user }} — {{ comment.createdAt|date('d/m/Y H:i') }}
            </small>
        </div>
    </div>
    {% else %}
    <p>Aucun commentaire pour le moment.</p>
    {% endfor %}

    <hr>

    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
    {% if app.user.isActive or is_granted('ROLE_ADMIN') %}
    <h4>Laisser un commentaire</h4>
    {{ form_start(commentForm) }}
    {{ form_row(commentForm.content) }}
    <button type="submit" class="btn btn-primary mt-2">Envoyer</button>
    {{ form_end(commentForm) }}
    {% else %}
    <div class="alert alert-warning">
        ⏳ Votre compte est en attente de validation par un administrateur.
        Vous pourrez commenter une fois votre compte approuvé.
    </div>
    {% endif %}
    {% else %}
    <p>
        <a href="{{ path('app_login') }}">Connectez-vous</a> pour laisser un commentaire.
    </p>
    {% endif %}

</div>
{% endblock %}