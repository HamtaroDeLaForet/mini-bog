{% extends 'base.html.twig' %}

{% block title %}Accès refusé{% endblock %}

{% block body %}
<div class="container mt-5 text-center" style="max-width: 600px;">

    <div style="font-size: 6rem; animation: shake 0.5s infinite alternate;">🕵️</div>

    <h1 class="mt-3 mb-2" style="font-weight: 900; font-size: 2.5rem;">
        Eh oh petit filou 👀
    </h1>

    <p class="text-muted mb-1" style="font-size: 1.1rem;">
        T'as cru que tu pouvais aller là où tu veux ?
    </p>
    <p class="text-muted mb-4" style="font-size: 1rem;">
        Cette zone est réservée aux admins. Circule, y'a rien à voir. 🚧
    </p>

    <div class="p-3 mb-4 rounded-3" style="background: #fff3cd; border: 2px dashed #ffc107; font-size: 0.9rem; color: #856404;">
        🚨 Tentative d'intrusion enregistrée... <br>
        <small class="text-muted">(non, on rigole. Mais quand même.)</small>
    </div>

    <a href="{{ path('app_home') }}" class="btn btn-primary btn-lg px-5">
        Rentrer sagement 🏠
    </a>

</div>

<style>
    @keyframes shake {
        from { transform: rotate(-5deg); }
        to   { transform: rotate(5deg); }
    }
</style>
{% endblock %}